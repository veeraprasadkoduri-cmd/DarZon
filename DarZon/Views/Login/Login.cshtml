@model DarZon.Models.C_USER_MASTER
@{
    ViewBag.Title = "Login";
    Layout = null;
}

<html lang="en">
<head>
    <title>Darzan Tailor</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <link rel="icon" type="../image/png" sizes="32x32" href="../img/favicon.png">


    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.7.2/css/all.css"
          integrity="sha384-fnmOCqbTlWIlj8LyTjo7mOUStjsKC4pOpQbqyi7RrhN7udi9RwhKkMHpvLbHG9Sr" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css?family=Montserrat" rel="stylesheet" />
    <link rel="stylesheet" href="../css/style.css" />
    <link href="https://unpkg.com/gijgo@1.9.13/css/gijgo.min.css" rel="stylesheet" type="text/css" />
</head>

<body>
    <!-- Login -->
    <section class="login-sec">
        <div class="container h-100">
            <div class="d-flex justify-content-center h-100">
                <div class="d-flex justify-content-center form_container">
                    <form class="form-signin">
                        <div class="text-center">
                            <img class="mb-4" src="~/img/logo_darzan-d.svg" alt="logo">
                        </div>

                        <div class="form-group">
                            <input type="text" name="" class="form-control input_user" placeholder="Username" id="UserName">
                        </div>

                        <div class="form-group">
                            <input type="password" name="" class="form-control input_pass" value="" placeholder="Password" id="Password">

                        </div>
                        <div class="checkbox my-2">
                            <label>
                                <input type="checkbox"> <span class="font-weight-bold">Remember me</span>
                            </label>
                        </div>

                        <input type="button" class="btn btn-light btn-block font-weight-bold" id="btnLogin" value="LOGIN" />
                        <div class="mt-4">
                            <div class="d-flex justify-content-center links font-weight-bold">
                                Don't have an account? <a href="sign-up.html" class="ml-2 font-weight-bold clr-hovr">Sign Up</a>
                            </div>
                            <div class="d-flex justify-content-center links">
                                <a href="../Forgotpwd/Index" class="font-weight-bold clr-hovr">Forgot your Password?</a>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </section>


    <!-- End of Login -->

    <script src="~/Scripts/jquery-3.1.1.min.js"></script>
    <script src="~/Scripts/popper.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>

    <script src="../js/Login.js"></script>
    <script src="../js/Validation.js"></script>
    <script src="../js/custom.js"></script>


</body>

</html>