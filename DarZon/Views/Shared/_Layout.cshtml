    @RenderSection("scripts", required: false)
    <script>
        if ($("#Camera").length) {
            $("#Camera").webcam({
                width: 320,
                height: 240,
                mode: "save",
                swffile: "@Url.Content("~/js/jscam.swf")",
                onTick: function () { },
                onSave: function () {
                    UploadPic();
                },
                onCapture: function () {
                    webcam.save("@Url.Content("~/Camera/Capture")/");
                    // webcam.save(methodsave());
                },
                debug: function () { },
                onLoad: function () { }

            })
        }
        $(document).ready(function () {
            debugger;
            ValuesMainList();
            if ('@ViewBag.popalt' != null)
            {
                if ('@ViewBag.popalt' == "Success")
                {
                    
                    $('#printdocument').modal('show');
                }

            }
            if ('@ViewBag.saleordersuccess'!=null)
            {
                if ('@ViewBag.saleordersuccess'== "Sucess")
                {
                    
                    $('#PrintSendMAil').modal('show');
                }

            }
            



            if ($("#printvisible").length) {
                if ($("#printvisible").val() == "Print") {
                    $('#Savedetails').modal('show');

                }
        }

            $("#logout").click(function () {


                                window.location.href = '../Home/Logout';
                            });
            $("#stay").click(function () {

                            });

            if ($("#hdnStatus").length)
            {
                if ($("#hdnStatus").val() == 'C') {
                    $("#divitemlist :input").prop('disabled', true);
                    $("#paymentdetails :input").prop('disabled', true);
                }
            }

            if ($("#mescurstatus").length)
            {

               
                if ($("#mescurstatus").val() == "C")
                {
                    $("#mesdiv :input").prop('disabled', true);
                   
                }


            }

            


        });
        function methodsave() {
           
            var valUrl = "../Camera/Capture";
            var valData = { id: $('#imageurl').val() };

            $.ajax({
                type: "POST",
                url: valUrl,
                cache: false,
                data: valData,
                async: true,
                success: function (data) {

                    var markup = "<option value='0'>Select Sub Addon</option>";
                    for (var x = 0; x < data.length; x++) {
                        markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                    }
                    $("#dllsubgroup").html(markup).show();
                }
            });



        }
    
      







        function UploadPic()
        {  
        

            $.ajax({  
            type: 'POST',  
            url: ("@Url.Content("~/Camera/Rebind")/"),  
            dataType: 'json',  
            success: function (data) {  
                var url ="../App_Data/" +data;
                var eleid = $("#imageurl").val();
                var split = eleid.split('|');
               
                if(split.length > 1) {
                    var acpath = split[0] + split[1]
                    $("#" + acpath).val(url);
                    $("#measure").attr("src", url)

                }
                else {

                    var acpath = eleid + "url";
                    $("#" + eleid).attr("src", url);

                    $("#" + acpath).val(url);
                }
            }  
        })  

            $('#webcame').modal('hide');




        }  

        function mobileupload() {
            if (window.FormData !== undefined) {

                var fileUpload = $("#FileUpload1").get(0);
                var files = fileUpload.files;

                // Create FormData object  
                var fileData = new FormData();

                // Looping over all files and add it to FormData object  
                for (var i = 0; i < files.length; i++) {
                    fileData.append(files[i].name, files[i]);
                }

                // Adding one more key to FormData object  
                fileData.append('username', 'Manas');

                $.ajax({
                    url: '/Camera/UploadFiles',
                    type: "POST",
                    contentType: false, // Not to set any content header  
                    processData: false, // Not to process data  
                    data: fileData,
                    success: function (result) {
                        UploadPic();
                    },
                    error: function (err) {
                        alert(err.statusText);
                    }
                });
            } else {
                alert("FormData is not supported.");
            }
        }

              function stopCarret() {
                  if ($("#txtOTP").val().length > 2) {
                      var element = document.getElementById('txtOTP');  
                      setCaretPosition(element,3);
            }
        }

        function setCaretPosition(elem, caretPos) {
            if (elem != null) {
                debugger;
                if (elem.createTextRange) {
                    var range = elem.createTextRange();
                    range.move('character', caretPos);
                    range.select();
                }
                else {
                    if (elem.selectionStart) {
                        elem.focus();
                        elem.setSelectionRange(caretPos, caretPos);
                    }
                    else
                        elem.focus();
                }
            }
        }
        function ValuesMainList() {


            var valUrl = "../Measurmentdetails/mainsubgrouplist";
            var valData = { id: $("#ItemCode").val() };

            $.ajax({
                type: "POST",
                url: valUrl,
                cache: false,
                data: valData,
                async: false,
                success: function (data) {

                    var markup = "<option value='0'>Select Addon</option>";

                    for (var x = 0; x < data.length; x++) {
                        markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                    }
                    $("#dlladdonroup").html(markup).show();
                }
            });



        }
      
    </script>

