@model  ICollection<DarZon.Models.SaleOrderDetail>
@{
    Layout = null;
}


<div class="table-responsive tableFixHead">
    <table class="table table-bordered table-sm table-hover" id="orderdetails">
        <thead class="thead-light">
            <tr>
                <th scope="col">S.No</th>
                <th scope="col">Item&nbsp;Code</th>
                <th scope="col">Description</th>
                <th scope="col">Qty</th>
                <th scope="col">Rate</th>
                @*<th scope="col">Tax</th>*@
                <th scope="col">Total</th>
                <th scope="col">Delivery</th>
                <th scope="col">Remarks</th>
            </tr>
        </thead>
        <tbody>

            @for (int i = 0; i < Model.Count(); i++)
            {

                using (Html.BeginCollectionItem("objsaleorder"))
                {

                    <tr>
                        <td></td>
                        <td>
                            @Html.TextBoxFor(item => Model.ElementAt(i).ItemCode, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })
                        </td>
                        <td>
                            @Html.TextBoxFor(item => Model.ElementAt(i).ItemDescription, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })
                        </td>
                        <td>
                            @Html.TextBoxFor(item => Model.ElementAt(i).quantity, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })
                        </td>
                        <td>
                            @Html.TextBoxFor(item => Model.ElementAt(i).UnitPrice, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })
                            @Html.HiddenFor(item => Model.ElementAt(i).taxCode, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })
                            @Html.HiddenFor(item => Model.ElementAt(i).linenumber, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })
                            @Html.HiddenFor(item => Model.ElementAt(i).saleorderNo, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })
                        </td>

                        @*<td>
                                @Html.TextBoxFor(item => Model.ElementAt(i).TaxAmount, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })

                            </td>*@



                        <td>
                            @Html.TextBoxFor(item => Model.ElementAt(i).TotalAmount, new { @class = "totalamount form-control form-control-sm item-sel", @readonly = "readonly" })
                        </td>
                        <td>
                            @Html.TextBoxFor(item => Model.ElementAt(i).Deliverydate, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })
                        </td>

                        <td>
                            @Html.TextBoxFor(item => Model.ElementAt(i).Remarks, new { @class = "form-control form-control-sm item-sel", @readonly = "readonly" })
                        </td>
                    </tr>




                }

            }


        </tbody>
    </table>
</div>