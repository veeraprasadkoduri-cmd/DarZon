@model  IEnumerable<DarZon.Models.C_USER_MASTER>
@{
    ViewBag.Title = "Itemlist";
    Layout = null;
}
@if (Model != null)
{
    if (Model.Count() > 0)
    {


        for (int i = 0; i < Model.Count(); i = i + 4)
        {


<div class="row">

    @if (i < Model.Count())
    {
        <div class="col-lg-3 col-sm-6">
            <a href="@Model.ElementAt(i).U_TemPath">
                <div class="card mb-3 card-cmn">
                    <i class="@Model.ElementAt(i).U_Hmicons"></i>
                    <div class="card-body">
                        <p class="card-text text-center font-weight-bold text-uppercase">@Model.ElementAt(i).U_Screens</p>
                    </div>
                </div>
            </a>
        </div>


    }



    @if (i + 1 < Model.Count())
    {
        <div class="col-lg-3 col-sm-6">
            <a href="@Model.ElementAt(i+1).U_TemPath">
                <div class="card mb-3 card-cmn">
                    <i class="@Model.ElementAt(i+1).U_Hmicons"></i>
                    <div class="card-body">
                        <p class="card-text text-center font-weight-bold text-uppercase">@Model.ElementAt(i + 1).U_Screens</p>
                    </div>
                </div>
            </a>
        </div>


    }

    @if (i + 2 < Model.Count())
    {
        <div class="col-lg-3 col-sm-6">
            <a href="@Model.ElementAt(i+2).U_TemPath">
                <div class="card mb-3 card-cmn">
                    <i class="@Model.ElementAt(i+2).U_Hmicons"></i>
                    <div class="card-body">
                        <p class="card-text text-center font-weight-bold text-uppercase">@Model.ElementAt(i + 2).U_Screens</p>
                    </div>
                </div>
            </a>
        </div>


    }

    @if (i + 3 < Model.Count())
    {
        <div class="col-lg-3 col-sm-6">
            <a href="@Model.ElementAt(i+3).U_TemPath">
                <div class="card mb-3 card-cmn">
                    <i class="@Model.ElementAt(i+3).U_Hmicons"></i>
                    <div class="card-body">
                        <p class="card-text text-center font-weight-bold text-uppercase">@Model.ElementAt(i+3).U_Screens</p>
                    </div>
                </div>
            </a>
        </div>

    }



</div>


            }







        }



    }




  
