
@model  IEnumerable<DarZon.Models.DeliveryHead>
@{

    Layout = null;
}
<div class="modal-header">
    <h5 class="modal-title" id="exampleModalCenterTitle">Delivery List</h5>
    <div class="form-inline">
        <div class="form-inline">
            <div class="form-group mx-sm-3 mb-2">
                <input type="text" id="ItemInput" onkeyup="filtertable(this, 'Orderstatuslistfrmdatetodate')" class="form-control form-control-sm" placeholder="Search here">
            </div>
        </div>
    </div>
</div>
<div class="col">
    <div class="table-responsive tableFixHead">
        <table class="table table-bordered table-sm table-hover list-table" id="allocation">
            <thead class="thead-light">
                <tr>
                    <th>S.No</th>
                    <th>Doc NO</th>
                    <th>SaleOrderNo</th>
                    <th>Customer Name&nbsp;</th>



                </tr>
            </thead>
            <tbody>
                @if (Model.Count() > 0)
                {
                    foreach (var items in Model)
                    {
                        <tr>
                            <td></td>
                            <td>
                                <span class="custcode">@items.SaleOrderNo</span>
                                <button type="button" class="btn btn-secondary btn-sm add-btn" data-dismiss="modal"
                                        aria-label="Add" id="btnalloc" onclick="select(this)">
                                    Select
                                </button>
                            </td>
                            <td>@items.websaleorder</td>
                            <td class="custname">@items.CustomerName</td>

                        </tr>



                    }

                }


            </tbody>
        </table>
    </div>
    <div class="modal-footer"> <button type="button" class="btn btn-dark btn-sm" data-dismiss="modal" aria-label="Close">Close</button></div>
</div>
