
@model IEnumerable<DarZon.Models.InvoiceHead>
@{
    Layout = null;
}
<div class="table-responsive tableFixHead">
    <table class="table list-table table-bordered table-sm table-hover" id="orderlist">
        <thead class="thead-light">
            <tr>
                <th>S.No</th>
                <th>Delivery&nbsp;No</th>
                <th>SaleorderNo</th>
                <th>Document&nbsp;Date</th>
                <th>Customer&nbsp;Name</th>
                <th>Doc&nbsp;Total</th>

            </tr>
        </thead>
        <tbody>

            @if (Model.Count() > 0)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td></td>
                        <td>
                            <span class="SaleOrderNo" style="display:none">@item.DeliveryNo</span>
                            <span class="altdate" style="display:none"> @item.AltDate</span>
                            <span class="CustomerNo" style="display:none"> @item.CustomerNo</span>
                            <span class="DelDate" style="display:none"> @item.DeliveryDate</span>
                            <span class="AltDetails" style="display:none"> @item.AltDetails</span>
                            <span class="TotalBefDis" style="display:none"> @item.TotalBefDis</span>
                            <span class="advance" style="display:none"> @item.Advance</span>
                            <span class="WebSaleNo" style="display:none"> @item.websaleorder</span>
                            
                            <span class="Tax" style="display:none"> @item.Tax</span>&nbsp;&nbsp;&nbsp;&nbsp;
                            @item.DeliveryNo
                            <button type="button" class="btn btn-secondary btn-sm add-btn" data-dismiss="modal"
                                    aria-label="Add" id="btnaddOrder" onclick="SelectOrderRow(this)">
                                Select
                            </button>
                        </td>
                        <td>@item.websaleorder</td>
                        <td class="saleorderdate">
                            @item.DeliveryDate
                        </td>
                        <td class="CustomerName">
                            @item.CustomerName

                        </td>

                        <td class="DocTotal">
                            @item.DocTotal


                        </td>



                    </tr>
                }

            }
        </tbody>
    </table>
</div>

