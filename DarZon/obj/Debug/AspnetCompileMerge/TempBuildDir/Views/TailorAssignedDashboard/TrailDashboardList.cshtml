
@model  IEnumerable<DarZon.Models.Tailorchilddata>
@{
    /**/
    Layout = null;
}
<div class="col">
    <div class="table-responsive tableFixHead">
        <table class="table table-bordered table-sm table-hover tblsrial list-table" id="ReAllocation">
            <thead class="thead-light">
                <tr>
                    <th>SNo</th>
                    <th>SaleOrder&nbsp;No</th>
                    <th>Customer Name&nbsp;</th>



                </tr>
            </thead>
            <tbody>

                @foreach (var items in Model)
                {
                    <tr>
                        <td></td>
                        <td>
                            <span class="custcode">@items.saleorder</span>
                            <button type="button" class="btn btn-secondary btn-sm add-btn" data-dismiss="modal"
                                    aria-label="Add" id="btnaddCust">
                                Select
                            </button>
                        </td>
                        <td class="custname">@items.custname</td>

                    </tr>



                }




            </tbody>
        </table>
    </div>
</div>
<div class="modal-footer"> <button type="button" class="btn btn-dark btn-sm" data-dismiss="modal" aria-label="Close">Close</button></div>
