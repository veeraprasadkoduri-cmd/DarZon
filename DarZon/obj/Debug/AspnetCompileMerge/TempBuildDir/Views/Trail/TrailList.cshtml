@model  IEnumerable<DarZon.Models.Tailorchilddata>
    @{

    Layout = null;
    }

    <div class="col">
        <div class="col">
            <div class="table-responsive tableFixHead">
                <table class="table table-bordered table-sm table-hover tblsrial list-table" id="allocation">
                    <thead class="thead-light">
                        <tr>
                            <th>S.No</th>
                            <th>Doc&nbsp;No.</th>
                            <th>SaleOrderNo</th>
                            

                            <th>Customer&nbsp;No.</th>
                            <th>Customer&nbsp;Name</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count() > 0)
                        {
                            foreach (var items in Model)
                            {
                                <tr>
                                    <td></td>
                                    <td>
                                        <span class="SaleOrderNo" style="display:none">@items.saleorder</span>

                                        @items.saleorder
                                        <button type="button" class="btn btn-secondary btn-sm add-btn" data-dismiss="modal"
                                                aria-label="Add" id="btnalloc" onclick="SelectTrailRecord(this)">
                                            Select
                                        </button>
                                    </td>
                                    <td> <span class="webSaleOrderNo">@items.websaleoredr</span></td>
                                    <td class="CustomerNo">@items.CustomerNo</td>
                                    <td class="custname">@items.custname</td>

                                </tr>



                            }

                        }


                    </tbody>
                </table>
            </div>
            <div class="modal-footer"> <button type="button" class="btn btn-dark btn-sm" data-dismiss="modal" aria-label="Close">Close</button></div>
        </div>
        </div>
