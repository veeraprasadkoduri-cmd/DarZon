
@model DarZon.Models.Tailorassignment

@{
        
       ViewBag.Title = "Tailorassignment";

}

@using (Html.BeginForm())
{

    <section>
        <div class="container-fluid">
            <div class="row">
                <div class="col-xl-10 col-lg-9 col-md-8 ml-auto overflow-hidden">
                    <div class="row">
                        <div class="col mt-2">
                            <div class="card">
                                <h5 class="card-header">Tailor Assignment</h5>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-xl-6 col-lg-6 col-md-12">
                                            <div class=my-form>
                                                <div class="form-group row">
                                                    <label class="col-lg-4 col-md-12 col-sm-12">From&nbsp;Date</label>
                                                    <div class="jquery-datepicker col-lg-8 col-md-12 col-sm-12">
                                                        @Html.TextBoxFor(item => item.Objdate.fromdate
                                               , new { @class = "jquery-datepicker__input form-control form-control-sm", @id = "fromdate", @placeholder = "From Date.", onmousedown = "datepicker(this)",@readonly="readonly" })
                                                    </div>

                                                </div>
                                                <div class="form-group row">
                                                    <label class="col-lg-4 col-md-12 col-sm-12">To&nbsp;Date</label>
                                                    <div class="jquery-datepicker col-lg-8 col-md-12 col-sm-12">
                                                        @Html.TextBoxFor(item => item.Objdate.todate
                                               , new { @class = "jquery-datepicker__input form-control form-control-sm", @id = "todate", @placeholder = "To Date.", @onmousedown = "datepicker(this)", @readonly = "readonly" })
                                                    </div>
                                                </div>
                                                <div class="form-group row">
                                                    <div class="col-lg-4 col-md-12 col-sm-12">

                                                        <button type="button" id="Allocation" value="Allocation" class="btn btn-secondary btn-sm view-btn m-1" onclick="getAcclocateddata();">Allocation</button>
                                                    </div>
                                                    <div class="col-lg-8 col-md-12 col-sm-12">

                                                        @*<button type="button" id="ReAllocation" value="Reallocation"
                                                                class="btn btn-secondary btn-sm m-1 view-btn" onclick="reallocateddata()">
                                                            ReAllocation
                                                        </button>*@
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-xl-6 col-lg-6 col-md-12">
                                            <div class=my-form>
                                                <div class="form-group row">
                                                    <label for="UserID" class="col-lg-4 col-md-12 col-sm-12">User ID</label>
                                                    <div class="col-lg-8 col-md-12 col-sm-12">
                                                        @*<input type="text" class="form-control form-control-sm" id="UserID" placeholder="User ID">*@

                                                        @Html.TextBox("FirstName", (string)ViewBag.uname, new { @class = "form-control form-control-sm", @readonly = true })

                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    </div>


                                   




                                    @if (Model.objchilddata != null)
                                    {
                                        <div class="table-responsive tableFixHead">
                                            <table class="table table-bordered table-sm table-hover list-table" id="TailorAssignement">
                                                <thead class="thead-light">
                                                    <tr>
                                                        <th>View</th>
                                                        <th scope="col">Doc&nbsp;No.</th>
                                                        <th scope="col">SaleOrderNo</th>
                                                        <th scope="col">Line&nbsp;No.</th>
                                                        <th scope="col">Label&nbsp;No.</th>
                                                        <th scope="col">Item&nbsp;Code</th>
                                                        <th scope="col">Description</th>
                                                        <th scope="col">SaleorderDate</th>

                                                        <th scope="col">Production&nbsp;Designer</th>
                                                        <th scope="col">Master&nbsp;Tailor</th>
                                                        <th scope="col">Internal&nbsp;Delivery&nbsp;Date</th>
                                                        <th scope="col">Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>

                                                  


                                                    @for (int i = 0; i < Model.objchilddata.Count(); i++)
                                                    {
                                                        using (Html.BeginCollectionItem("objchilddata"))
                                                        {

                                                    <tr>
                                                        <td><a href="../Measurmentdetails/viewmeasurement?parentId=@Model.objchilddata.ElementAt(i).MPI">View</a></td>

                                                        <td>
                                                            @Model.objchilddata.ElementAt(i).saleorder
                                                            @Html.HiddenFor(a => Model.objchilddata.ElementAt(i).saleorder)
                                                        </td>
                                                        <td>
                                                            @Model.objchilddata.ElementAt(i).websaleoredr
                                                        </td>
                                                        <td>
                                                            @Model.objchilddata.ElementAt(i).lineno
                                                     @Html.HiddenFor(a => Model.objchilddata.ElementAt(i).lineno)
                                                                                                            </td>
                                                        <td> @Model.objchilddata.ElementAt(i).LabelNo</td>

                                                        <td>
                                                            @Model.objchilddata.ElementAt(i).itemcode
                                                            @Html.HiddenFor(a => Model.objchilddata.ElementAt(i).itemcode)
                                                        </td>
                                                        <td>
                                                            @Model.objchilddata.ElementAt(i).Description
                                                            @Html.HiddenFor(a => Model.objchilddata.ElementAt(i).Description)
                                                        </td>

                                                        <td>
                                                            @Model.objchilddata.ElementAt(i).schedulefordelivey
                                                            @Html.HiddenFor(a => Model.objchilddata.ElementAt(i).schedulefordelivey)
                                                        </td>

                                                       
                                                        <td>
                                                            @if (Model.objchilddata.ElementAt(i).prdesigner != null)
                                                            {
                                                                @Html.DropDownListFor(a => Model.objchilddata.ElementAt(i).prdesigner, new SelectList(ViewBag.userlist, "Value", "Text"), @Model.objchilddata.ElementAt(i).prdesigner, new { @id = "ddlprdesign", @class = "custom-select my-1 mr-sm-2 item-drop", @onchange = "GetSelectedmaster(this)" })
                                                            }
                                                            else
                                                            {
                                                                @Html.DropDownListFor(a => Model.objchilddata.ElementAt(i).prdesigner, new SelectList(ViewBag.userlist, "Value", "Text"), "please select", new { @id = "ddlprdesign", @class = "custom-select my-1 mr-sm-2 item-drop", @onchange = "GetSelectedmaster(this)" })
                                                            }
                                                        </td>
                                                        @if (Model.objchilddata.ElementAt(i).mastertailor != null)
                                                        {
                                                            <td>@Html.DropDownListFor(a => Model.objchilddata.ElementAt(i).mastertailor, new SelectList("", "Value", "Text"), @Model.objchilddata.ElementAt(i).mastertailor, new { @id = "mastertailor", @class = "master custom-select my-1 mr-sm-2 item-drop ", @onchange = "GetSelectedTextValue(this)" })</td>
                                                        }
                                                        else
                                                        {
                                                            <td>@Html.DropDownListFor(a => Model.objchilddata.ElementAt(i).mastertailor, new SelectList("", "Value", "Text"), "Please select", new { @id = "mastertailor", @class = "master custom-select my-1 mr-sm-2 item-drop ", @onchange = "GetSelectedTextValue(this)" })</td>
                                                        }
                                                            <td>
                                                                @Model.objchilddata.ElementAt(i).internaldeliveydate
                                                                    @Html.HiddenFor(a => Model.objchilddata.ElementAt(i).internaldeliveydate)
                                                                                                                </td>
                                                            <td>
                                                                @Model.objchilddata.ElementAt(i).status
                                                     @Html.HiddenFor(a => Model.objchilddata.ElementAt(i).status)
                                                                                                                </td>


                                                        @*<td>@Html.DropDownListFor(a => Model.ElementAt(i).status, new SelectList(ViewBag.userlist, "Value", "Text"), "Please select", new { @id = "ddlactivitytype", @class = "form-control form control-sm" })</td>*@
                                                        <td>
                                                            @Html.HiddenFor(a => Model.objchilddata.ElementAt(i).custname)
                                                            @Html.HiddenFor(a => Model.objchilddata.ElementAt(i).Docentry, new { @id = "hdnStatus" })
                                                        </td>

                                                    </tr>
                                                           
                                                        }
                                                    }



                                                </tbody>
                                           
                                            
                                            
                                            </table>
                                        </div>
                                    }




                                    <hr>
                                    <div class="row">
                                        <div class="mx-auto">
                                            <input type="submit" name="Save" id="Save" value="Save" class="btn btn-secondary btn-sm" />
                                            &nbsp;&nbsp;
                                            <button type="button" id="close" class="btn btn-secondary btn-sm float-right" onclick="refreshpage()">Close</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>


      
    </section>
}

<script src="~/js/Tailorassignment.js"></script>