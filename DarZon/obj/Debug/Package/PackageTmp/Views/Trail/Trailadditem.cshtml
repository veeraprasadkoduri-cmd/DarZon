
@model  ICollection<DarZon.Models.Tailorchilddata>
@{
    Layout = null;
}
<div class="table-responsive tableFixHead">
    <table class="table table-bordered table-sm table-hover list-table">
        <thead class="thead-light">
            <tr>
                <th>S.No</th>
                <th scope="col">Label No.</th>
                <th scope="col">Item Code</th>
                <th scope="col">Description</th>
                @*<th scope="col">Schedule&nbsp;Delivery&nbsp;Date</th>*@
                @*<th scope="col">Master Tailor</th>
                <th scope="col">Production Designer</th>*@
                <th scope="col">Internal&nbsp;Delivery&nbsp;Date</th>
                <th scope="col">Status</th>
                @*<th scope="col">Trail Status</th>*@
            </tr>
        </thead>
        <tbody>

            @for (int i = 0; i < Model.Count(); i++)
            {
                using (Html.BeginCollectionItem("objchilddata"))
                {

            <tr>
                <td></td>

                <td>
                    @Model.ElementAt(i).LabelNo

                                @Html.HiddenFor(item => Model.ElementAt(i).lineno)
                            </td>



                <td>@Model.ElementAt(i).itemcode</td>
                <td>
                    @Model.ElementAt(i).Description

                </td>

                @*<td>
                    @Model.ElementAt(i).schedulefordelivey

                </td>*@

                @*ViewBag.status*@

                <td>@Model.ElementAt(i).internaldeliveydate</td>
              
                <td>
                    @Html.DropDownListFor(a => @Model.ElementAt(i).Trailstatus, new SelectList(ViewBag.status, "Value", "Text"), "Please select", new { @id = "ddlprdesign", @class = "custom-select my-1 mr-sm-2 item-drop" })
                                @Html.HiddenFor(a => Model.ElementAt(i).custname)

                                @Html.HiddenFor(item => Model.ElementAt(i).prdesigner)


                                @Html.HiddenFor(item => Model.ElementAt(i).mastertailor)


                                @Html.HiddenFor(a => Model.ElementAt(i).Docentry, new { @id = "hdnStatus" })
                            </td>
              
            </tr>
                }
            }




        </tbody>
    </table>
</div>

