@model IEnumerable<DarZon.Models.InvoiceHead>
@{
    Layout = null;
}


<div class="table-responsive tableFixHead">
    <table class="table list-table table-bordered table-sm table-hover" id="InvoiceList">
        <thead class="thead-light">
            <tr>
                <th>S.No</th>
                <th>SaleorderNo</th>
                <th>Invoice No</th>
                <th>Document&nbsp;Date</th>
                <th>Customer&nbsp;Name</th>
                <th>Doctotal</th>

            </tr>
        </thead>
        <tbody>

            @if (Model.Count() > 0)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td></td>
                        <td class="WebSaleorder">@item.websaleorder</td>
                        <td>
                            <span class="SaleOrderNo" style="display:none">@item.InvoiceNo</span>
                            <span class="altdate" style="display:none"> @item.AltDate</span>
                            <span class="CustomerNo" style="display:none"> @item.CustomerNo</span>
                            <span class="DelDate" style="display:none"> @item.DeliveryDate</span>
                            <span class="AltDetails" style="display:none"> @item.AltDetails</span>
                            <span class="TotalBefDis" style="display:none"> @item.TotalBefDis</span>
                            <span class="delve" style="display:none"> @item.DeliveryNo</span>
                            <span class="advance" style="display:none"> @item.Advance</span>
                            <span class="Tax" style="display:none"> @item.Tax</span>
                            <span class="Curadv" style="display:none"> @item.CurrentAdvance</span>
                       
                            <span class="discount" style="display:none"> @item.discount</span>


                            &nbsp;&nbsp;&nbsp;&nbsp;

                            @item.InvoiceNo
                            <button type="button" class="btn btn-secondary btn-sm add-btn" data-dismiss="modal"
                                    aria-label="Add" id="btnaddInv" onclick="SelectInvoiceRow(this)">
                                Select
                            </button>
                        </td>

                        <td class="saleorderdate">
                            @item.DeliveryDate
                        </td>
                        <td class="CustomerName">
                            @item.CustomerName

                        </td>

                        <td class="DocTotal">
                            @item.DocTotal


                        </td>



                    </tr>
                }

            }
        </tbody>
    </table>
</div>

