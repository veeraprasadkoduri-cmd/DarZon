@model  IEnumerable<DarZon.Models.CustomerMaster>
@{
    ViewBag.Title = "customerlist";
    Layout = null;
}
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title" id="exampleModalCenterTitle">Customer List</h5>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@Html.ActionLink("NewCustomer", "CustomerMaster", "CustomeDetailsr")
        <div class="form-inline">
            <div class="form-group mx-sm-3 mb-2">
                <input type="text" id="ItemInput" onkeyup="filtertable(this, 'CustomerList')" class="form-control form-control-sm" placeholder="Search here">
            </div>
        </div>

    </div>
    <div class="col">

        <div class="table-responsive tableFixHead">
            <table class="table table-bordered table-sm table-hover list-table" id="CustomerList">
                <thead class="thead-light">
                    <tr>
                        <th>S.No</th>
                        <th>Customer&nbsp;Code</th>
                        <th>Customer Name</th>
                        <th>Mobile No</th>

                    </tr>
                </thead>
                <tbody>

                    @foreach (var customer in Model)
                    {
                        <tr>
                            <td></td>
                            <td>
                                <span class="custcode">@customer.customercode</span> <button type="button" class="btn btn-secondary btn-sm add-btn" data-dismiss="modal"
                                                                                             aria-label="Select" onclick="selectCustomer(this)">
                                    Select
                                </button>

                                <span class="AltrphoneNo d-none">@customer.AltrphoneNo</span>

                                <span class="Area d-none" style="display:none">@customer.Area</span>
                                <span class="Block d-none" style="display:none">@customer.Block</span>
                                <span class="city d-none" style="display:none">@customer.city</span>
                                <span class="CustTYpe d-none" style="display:none">@customer.CustTYpe</span>
                                <span class="DoorNo d-none" style="display:none">@customer.DoorNo</span>
                                <span class="Emailid d-none" style="display:none">@customer.Emailid</span>
                                <span class="Landmark d-none" style="display:none">@customer.Landmark</span>
                                <span class="PhoneNumber d-none" style="visibility:hidden">@customer.PhoneNumber</span>
                                <span class="Pincode d-none" style="visibility:hidden">@customer.Pincode</span>
                                <span class="State d-none" style="visibility:hidden">@customer.State</span>
                                <span class="Street d-none" style="visibility:hidden">@customer.Street</span>
                                <span class="Anniversery d-none" style="visibility:hidden">@customer.Anniversery</span>
                                <span class="DBO d-none" style="visibility:hidden">@customer.DBO</span>

                            </td>
                            <td class="custname">@customer.CustomerName</td>
                            <td class="custphone">@customer.PhoneNumber</td>
                        </tr>


                    }




                </tbody>
            </table>
        </div>

    </div>
    <div class="modal-footer">&nbsp;   <button type="button" class="btn btn-dark btn-sm" data-dismiss="modal" aria-label="Close">Close</button></div>
</div>