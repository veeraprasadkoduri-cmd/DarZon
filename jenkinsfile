pipeline {
    agent any
    environment {
        IMAGE_NAME = "veeradockerhub/darzon:latest"
        PORT = "5000"
    }
    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/veeraprasadkoduri-cmd/DarZon.git'
            }
        }
        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${IMAGE_NAME} ."
            }
        }
        stage('Run Container') {
            steps {
                sh """
                docker rm -f darzon || true
                docker run -d -p ${PORT}:5000 --name darzon ${IMAGE_NAME}
                """
            }
        }
    }
}
